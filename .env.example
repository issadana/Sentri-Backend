# Copy to .env and fill in real values. Never commit the real .env.
# Generate strong secrets with:  python -c "import secrets; print(secrets.token_urlsafe(48))"

SECRET_KEY=put_any_secret_here
JWT_SECRET_KEY=put_any_jwt_secret_here

# Remote deployed PostgreSQL (Linode). Replace with your actual connection string.
DATABASE_URL=postgresql://dbuser:YOUR_PASSWORD@YOUR_LINODE_HOST:5432/sentridb

# Groq API key for the mobile SSE chatbot. Get one at https://console.groq.com/keys
GROQ_API_KEY=put_your_groq_api_key_here

# Local Ollama for the NOVA dashboard (runs on your machine with GPU)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Local dashboard port (default Flask dev server)
PORT=5000
