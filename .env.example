# Copy to .env and fill in real values. Never commit the real .env.
# Generate secrets with:  python -c "import secrets; print(secrets.token_urlsafe(48))"

SECRET_KEY=put_any_secret_here
JWT_SECRET_KEY=put_any_jwt_secret_here

# Remote deployed PostgreSQL (Linode) — same DB your friend's backend writes to.
DATABASE_URL=postgresql://dbuser:YOUR_PASSWORD@YOUR_LINODE_HOST:5432/sentridb

# Local Ollama for the NOVA dashboard (runs on your machine)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

PORT=5000
