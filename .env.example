# Copy to .env and fill in real values. Never commit the real .env.
# Generate strong secrets with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=put_any_secret_here
JWT_SECRET_KEY=put_any_jwt_secret_here
DATABASE_URL=postgresql://dbuser:YOUR_PASSWORD@localhost:5432/neural_firewalldb
# Groq API key for the SSE chatbot. Get one at https://console.groq.com/keys
GROQ_API_KEY=put_your_groq_api_key_here
